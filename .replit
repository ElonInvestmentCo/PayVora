modules = ["nodejs-24", "python-3.11"]

# ─────────────────────────────
# ONLY ONE ACTIVE ARTIFACT
# ─────────────────────────────
[[artifacts]]
id = "artifacts/giftcard-trader"

# ─────────────────────────────
# DEPLOYMENT
# ─────────────────────────────
[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

# ─────────────────────────────
# WORKFLOWS (CLEAN SINGLE APP)
# ─────────────────────────────
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN pnpm --filter @workspace/giftcard-trader exec expo start --web --port 5000 --clear"
waitForPort = 5000

# ─────────────────────────────
# AGENT CONFIG
# ─────────────────────────────
[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

# ─────────────────────────────
# POST MERGE
# ─────────────────────────────
[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

# ─────────────────────────────
# NIX ENV
# ─────────────────────────────
[nix]
packages = ["nano"]
channel = "stable-25_05"

# ─────────────────────────────
# PORT MAPPING
# ─────────────────────────────
[[ports]]
localPort = 5000
externalPort = 80
