modules = ["nodejs-20", "web", "bash"]

# ─────────────────────────────
# ONLY ONE ACTIVE ARTIFACT
# ─────────────────────────────
[[artifacts]]
id = "artifacts/giftcard-trader"

# ─────────────────────────────
# DEPLOYMENT
# ─────────────────────────────
[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

# ─────────────────────────────
# WORKFLOWS (CLEAN SINGLE APP)
# ─────────────────────────────
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN pnpm --filter @workspace/giftcard-trader exec expo start --web --port 5000 --clear"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start PayVora App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PayVora Website"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start PayVora App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_EXPO_DEV_DOMAIN pnpm --filter @workspace/giftcard-trader exec expo start --web --port 5000 --clear"
waitForPort = 5000

[[workflows.workflow]]
name = "PayVora Website"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 pnpm --filter @workspace/payvora-website run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

# ─────────────────────────────
# AGENT CONFIG
# ─────────────────────────────
[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

# ─────────────────────────────
# POST MERGE
# ─────────────────────────────
[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

# ─────────────────────────────
# NIX ENV
# ─────────────────────────────
[nix]
packages = ["nano", "psmisc"]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080
